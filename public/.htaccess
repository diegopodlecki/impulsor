Options -MultiViews
RewriteEngine On

# Serve real files and folders directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Clean URLs for prerendered landing pages like /odontologos -> /odontologos.html.
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Fallback to the home page for any other client-side route.
RewriteRule ^ index.html [L]
