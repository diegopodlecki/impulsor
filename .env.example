# Impulsor Web (Vite) - variables de entorno
#
# Copia este archivo a `.env.local` (o configura variables en tu host).
#
# Teléfono de WhatsApp en formato internacional (solo dígitos).
VITE_WA_PHONE=541166448389

# Supabase
# Pegá estos valores desde tu proyecto en Supabase:
# - Project URL  -> VITE_SUPABASE_URL
# - anon public key -> VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=